# Copy this to .env.local and fill in your values.

# Neon Postgres connection string
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# MotherDuck token
# Get from: https://app.motherduck.com → Settings → Tokens
MOTHERDUCK_TOKEN=your_motherduck_token_here

# MotherDuck database name (must already exist in your MotherDuck account)
MOTHERDUCK_DATABASE=mayolo

# Anthropic API key
# Get from: https://console.anthropic.com → API Keys
AI_GATEWAY_API_KEY=sk-ant-...

# Base URL — use localhost for local dev, your Vercel URL in production
APP_BASE_URL=http://localhost:3000

# Comma-separated email allowlist — when set, only these addresses can sign in.
# Leave unset to allow anyone to sign in (open instance).
# EMAIL_ALLOW_LIST=you@gmail.com,colleague@example.com

# Comma-separated list of Google emails that are automatically app admins
# Admins can create datasets, see all datasets, and toggle public/private
APP_ADMIN_EMAILS=you@gmail.com,colleague@example.com

# Google OAuth — for user sign-in
# Get from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URIs: https://your-app.vercel.app/api/auth/callback/google
#                           http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your_google_client_id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your_google_client_secret

# Auth.js secret — used to sign session tokens and OAuth state blobs
# Generate one with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# Okta OAuth — optional, enables Okta sign-in when all three are set
# Get from: your Okta admin console → Applications → Create App Integration → OIDC
# Authorized redirect URIs: https://your-app.vercel.app/api/auth/callback/okta
#                           http://localhost:3000/api/auth/callback/okta
# AUTH_OKTA_CLIENT_ID=0oaxxxxxxxxxxxxxxxx
# AUTH_OKTA_CLIENT_SECRET=your_okta_client_secret
# AUTH_OKTA_ISSUER=https://yourorg.okta.com

# GitHub personal access token (optional)
# Required only for loading Malloy models from private GitHub repositories.
# Needs read access to repo contents (classic PAT scope: repo, or fine-grained: contents:read).
# Leave unset to use public repos only.
# GITHUB_TOKEN=github_pat_...
