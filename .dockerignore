# Keep secrets and local state out of Docker build context / image layers.
# (See PR #1 — the Dockerfile's `COPY . .` copies everything not listed here.)
local/
.env*
.git
# Exclude node_modules at EVERY level. A bare `node_modules` only matches the
# top-level dir in .dockerignore, so a stale packages/*/node_modules would be
# copied by `COPY . .` and shadow the clean `npm ci` layout (dangling .bin
# shims → "Cannot find module …/tsx").
**/node_modules
.next
.vercel
drizzle/meta
