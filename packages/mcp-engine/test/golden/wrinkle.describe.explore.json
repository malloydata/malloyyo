        "dimensions": {
          "code": {
            "type": "string"
          },
          "region_id": {
            "type": "string"
          }
        },
        "measures": {
          "wcarrier_count": {
            "type": "number",
            "expression": "count()"
          }
        }
      },
      "code": "join_one: carriers is wcarriers with carrier"
    },
    "carriers.region": {
      "source": "regions",
      "code": "join_one: region is regions with region_id"
    }
  },
  "join_source_map": {
