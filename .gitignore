# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
packages/*/node_modules
packages/*/dist

# generated at build time by scripts/embed-content.ts (content/ is the source of truth)
packages/*/src/content/generated.ts
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local configuration directory (private, never committed).
# Bare `local` (no slash) so it also catches a `local` *symlink*, not just a dir.
local

# env files
.env.local*
!.env.local.example

# secret material dropped at repo root by the user — never commit
*-key.txt
*.key
*-secret.txt
cloudflare-r2.txt
cloudlfare-r2.txt
*-r2.txt
anthropic-key.txt
vercel-ai-key.txt
secrets/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# terraform — commit the lock file, ignore state and tfvars
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
crash.log
crash.*.log

# data dumps / scratch
/tmp/
/scratch/
/public/dashboard-vendor.js
