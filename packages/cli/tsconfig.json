{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src",
    "test"
  ],
  "comment": "frame-entry.tsx is browser JSX bundled at runtime by esbuild, never imported by node code — kept out of the node typecheck.",
  "exclude": [
    "src/frame-entry.tsx"
  ]
}
