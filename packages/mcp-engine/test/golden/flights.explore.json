    "flights": {
      "name": "flights",
      "primary_key": "id",
      "description": "Flight facts, with nested route legs and free-form tags.",
      "instructions": "Grain is one row per flight; join carriers for airline names.",
      "dimensions": [
        {
          "name": "id",
          "type": "number"
        },
        {
          "name": "carrier",
          "type": "string"
        },
        {
          "name": "distance",
          "type": "number"
        }
      ],
      "measures": [
        {
          "name": "total_distance",
          "type": "number",
          "description": "Total distance flown.",
          "instructions": "Sum across flights; do not average a pre-summed value.",
          "expression": "distance.sum()"
        },
        {
          "name": "flight_count",
          "type": "number",
          "expression": "count()"
        }
      ],
      "views": [
        {
          "name": "by_carrier",
